@{
    Layout = "_GameLayout";
    ViewData["Title"] = "Truco RPG";
}

<div class="truco-page">
    <div class="game-shell">
        <div class="mesa">
            <div class="tapete">

                <aside class="panel-acciones">

                    <div class="slider-wrap">
                        <span class="switch-label">Mentira en Envido</span>
                        <input type="range" id="sliderMentiraEnvido" min="0" max="100" value="0" class="slider-mentira" />
                        <div class="slider-info">
                            <span>Honesto</span>
                            <strong id="valorMentiraEnvido">0</strong>
                            <span>Tramposo</span>
                        </div>
                    </div>

                    <div class="slider-wrap">
                        <span class="switch-label">Mentira en Truco</span>
                        <input type="range" id="sliderMentiraTruco" min="0" max="100" value="0" class="slider-mentira" />
                        <div class="slider-info">
                            <span>Honesto</span>
                            <strong id="valorMentiraTruco">0</strong>
                            <span>Tramposo</span>
                        </div>
                    </div>

                    <button id="btnEnvido"      class="btn btn-canto"            disabled>Envido</button>
                    <button id="btnRealEnvido"  class="btn btn-canto"            disabled>Real Envido</button>
                    <button id="btnFaltaEnvido" class="btn btn-canto"            disabled>Falta Envido</button>
                    <button id="btnTruco"       class="btn btn-canto btn-truco"  disabled>Truco</button>

                    <button id="btnIrseAlMazo" class="btn btn-mazo" disabled>Ir al mazo</button>

                    <div id="respuestaUsuarioWrap" class="respuesta-usuario d-none">
                        <div class="switch-label" id="labelRespuesta">Responder canto</div>
                        <button id="btnQuieroCanto"  class="btn btn-respuesta">Quiero</button>
                        <button id="btnNoQuieroCanto" class="btn btn-respuesta btn-no-quiero">No quiero</button>
                        <button id="btnRetruco"   class="btn btn-canto btn-truco d-none">Retruco</button>
                        <button id="btnValeCuatro" class="btn btn-canto btn-truco d-none">Vale Cuatro</button>
                    </div>

                    <button id="btnNuevaMano"    class="btn btn-nueva-mano">Nueva mano</button>
                    <button id="btnNuevaPartida" class="btn btn-nueva-partida">Nueva partida</button>
                </aside>

                <main class="mesa-principal">

                    <div id="cartelDecisionMaquina" class="cartel-decision d-none"></div>

                    <div class="tapete-3d" aria-hidden="true"></div>

                    <div class="zona-oponente">
                        <div class="oponente-retrato">
                            <div class="gaucho-fondo" aria-hidden="true"></div>
                            <span id="maquinaResumen" class="badge-estado">Esperando mano</span>
                        </div>
                        <div id="cartasMaquina" class="cartas-contenedor maquina-cartas"></div>
                    </div>

                    <div id="cartasJugadas" class="zona-cartas-jugadas panel-info">
                        Todavía no se jugó ninguna mano.
                    </div>

                    <div class="zona-jugador-3d">
                        <div id="cartasJugador" class="cartas-contenedor mano-jugador"></div>
                    </div>

                </main>

                <aside class="panel-info-juego">

                    <div class="historial-wrap marcador-rpg">
                        <div class="panel-titulo">Tanteador</div>
                        <div id="tanteadorPuntos" class="tanteador-palitos"></div>
                    </div>

                    <div class="historial-wrap">
                        <div class="panel-titulo">Envido</div>
                        <div id="estadoEnvido" class="panel-info">Todavía no se cantó envido.</div>
                        <hr class="separador-panel" />
                        <div class="panel-titulo">Truco</div>
                        <div id="estadoTruco" class="panel-info">Todavía no se cantó truco.</div>
                        <hr class="separador-panel" />
                        <div class="panel-titulo">Decisiones</div>
                        <div id="decisionesPartida" class="panel-info">Sin decisiones todavía.</div>
                    </div>

                </aside>

            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/truco/index.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/truco/index.js" asp-append-version="true"></script>
}
